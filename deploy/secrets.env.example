# yardmate-api secrets.env template
#
# COPY this file to a location OUTSIDE this repo (e.g.
# ~/.config/yardmate-api/secrets.env.prod), fill in real values, and point
# deploy.sh at it via YARDMATE_SECRETS=...
#
# NEVER commit a filled version. The repo's .gitignore covers `secrets.env`
# at any depth, but the safest habit is to keep the live copy outside the
# tree entirely.
#
# File format: see secrets/SPEC.md §2.

# ---- server config ----

# App Attest "development environment" gate. See deploy/README.md §3 for the
# stage-aware ship SOP. MUST be `false` once the App Store binary ships.
ATTEST_ALLOW_DEV=false

# ---- vended to authenticated clients ----

# OpenAI API key (GPT-4o-mini for plant chat / advice features).
OPENAI_API_KEY=sk-REPLACE-ME

# Plant.id API key (plant identification from photos).
PLANT_ID_API_KEY=REPLACE-ME

# ---- /v1/plants/enrichment (V1 plant-detail enrichment) ----

# Supabase Postgres DSN (Session Pooler form per proxy/enrichment/SPEC §9 #15).
# Get from Supabase Dashboard → Connect → Direct → "Session pooler" tab.
# Replace [YOUR-PASSWORD] with the actual DB password (use "Reset Database
# Password" in Dashboard if forgotten).
#
# DO NOT use the "Direct connection" DSN (db.<ref>.supabase.co:5432) —
# Supabase makes it IPv6-only by default and the Hetzner outbound IPv6 path
# is unreliable, which fails silently as a TCP timeout. Session Pooler is
# IPv4-routable and runs the same Postgres wire protocol so pgx connects
# identically (SPEC §9 #15).
SUPABASE_DB_URL=postgresql://postgres.REPLACE-REF:REPLACE-PASSWORD@aws-0-REPLACE-REGION.pooler.supabase.com:5432/postgres
